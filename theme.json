{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary",    "name": "Primary",    "color": "#1a3a52" },
        { "slug": "primary-dark","name": "Primary dark","color": "#0f2638" },
        { "slug": "accent",     "name": "Accent",     "color": "#c89968" },
        { "slug": "cta",        "name": "CTA",        "color": "#a04030" },
        { "slug": "text",       "name": "Text",       "color": "#1f1813" },
        { "slug": "bg",         "name": "Background", "color": "#fdfbf6" },
        { "slug": "surface",    "name": "Surface",    "color": "#f5ede0" },
        { "slug": "muted",      "name": "Muted",      "color": "#6b6359" }
      ],
      "custom": true,
      "customDuotone": true,
      "customGradient": true,
      "defaultPalette": false,
      "defaultGradients": false,
      "link": true
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "display",
          "name": "Display",
          "fontFamily": "Fraunces, Georgia, serif"
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "name": "XS",   "size": "0.8125rem" },
        { "slug": "sm",   "name": "S",    "size": "0.9375rem" },
        { "slug": "base", "name": "Base", "size": "1.0625rem" },
        { "slug": "lg",   "name": "L",    "size": "1.25rem"   },
        { "slug": "xl",   "name": "XL",   "size": "1.75rem"   },
        { "slug": "xxl",  "name": "XXL",  "size": "2.5rem"    },
        { "slug": "xxxl", "name": "XXXL", "size": "4rem"      }
      ],
      "fluid": true,
      "lineHeight": true,
      "letterSpacing": true,
      "textDecoration": true,
      "textTransform": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": ["px","rem","em","%","vh","vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1400px"
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text":       "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize":   "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "var(--wp--preset--font-size--xxxl)", "lineHeight": "1.1", "letterSpacing": "-0.02em" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "var(--wp--preset--font-size--xxl)",  "lineHeight": "1.15","letterSpacing": "-0.02em" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontSize": "var(--wp--preset--font-size--xl)",   "lineHeight": "1.2"  } },
      "link": { "color": { "text": "var(--wp--preset--color--cta)" } },
      "button": {
        "color":      { "background": "var(--wp--preset--color--cta)", "text": "#ffffff" },
        "border":     { "radius": "8px" },
        "typography": { "fontWeight": "600" },
        "spacing":    { "padding": { "top": "0.75rem", "bottom": "0.75rem", "left": "1.5rem", "right": "1.5rem" } }
      }
    },
    "spacing": {
      "padding": { "top": "0", "right": "var(--wp--preset--spacing--40)", "bottom": "0", "left": "var(--wp--preset--spacing--40)" }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header",  "area": "header" },
    { "name": "footer", "title": "Footer",  "area": "footer" }
  ]
}
